# =============================================================
# MOTOKA FRONTEND — ENVIRONMENT VARIABLES
# Copy this file to .env.development (local) or .env.production (prod build).
# NEVER commit .env.* files — they are gitignored.
# =============================================================

# Backend API base URL
VITE_API_BASE_URL=http://localhost:3000/api

# Environment label used internally
VITE_ENV=development

# =============================================================
# SUPABASE
# Get from: Supabase dashboard → Project Settings → API
# The anon key is safe to expose in the client — RLS protects your data.
# =============================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================
# TOKEN ENCRYPTION
# Used to encrypt the access token stored in localStorage.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Note: this value will be visible in the compiled JS bundle.
# =============================================================
VITE_CRYPTO_SECRET=your-32-char-random-string-here
